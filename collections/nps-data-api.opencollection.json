{
  "opencollection": "1.0.0",
  "info": {
    "name": "National Park Service (NPS) Data API",
    "version": "1"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "api_key",
      "value": "{{api_key}}",
      "placement": "query"
    }
  },
  "items": [
    {
      "info": {
        "name": "Parks",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List or search national parks",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://developer.nps.gov/api/v1/parks",
            "params": [
              {
                "name": "parkCode",
                "value": "",
                "type": "query",
                "description": "Comma-separated four-letter park codes (e.g. yose,grca)"
              },
              {
                "name": "stateCode",
                "value": "",
                "type": "query"
              },
              {
                "name": "q",
                "value": "",
                "type": "query",
                "description": "Free-text search"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "start",
                "value": "",
                "type": "query"
              }
            ]
          },
